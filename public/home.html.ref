rder-color: rgb(194, 181, 155); background-color: transparent;"><div class="CtaButton_overlay__vmYmc"></div><span class="CtaButton_text___uJH4 CtaButton_buttonTextSize__IPf1g" style="translate: none; rotate: none; scale: none; transform: translate(0px, 0px); color: rgb(194, 181, 155);">view our portfolio</span><div class="CtaButton_arrowWrapper__wm41s" style="translate: none; rotate: none; scale: none; transform: translate(0px, 0px); color: rgb(194, 181, 155);"><svg width="17" height="8" fill="currentColor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 17 8"><path d="M16.354 4.036a.5.5 0 000-.707L13.172.147a.5.5 0 10-.708.707l2.829 2.828-2.829 2.829a.5.5 0 10.708.707l3.182-3.182zM0 3.682v.5h16v-1H0v.5z" fill="#C2B59B"></path></svg></div></a></div></div></div><section class="CompaniesGroups_sectionWrapper__o8hXv"><h2 class="CompaniesGroups_title__wGEGv">OUR COMPANIES</h2><div class="CompaniesGroups_flexContainer__hsQP_"><div class="CompaniesGroups_categoryBox__z2NWA"><h3 class="CompaniesGroups_categoryTitle__y8Cwd">Commercial Construction</h3><div class="CompaniesGroups_itemsGrid__WZwNi" style="grid-template-columns:repeat(2, minmax(0, 15.6rem))"><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://bigdconstruction.com/"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="NATIONWIDE" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/9ef761df674530.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">NATIONWIDE</span></a><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://www.martinharris.com/"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="NEVADA / COLORADO" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/5a74ec845b0741.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">NEVADA / COLORADO</span></a><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://www.mcalvain.com/"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="IDAHO" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/870a887ee03018.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">IDAHO</span></a></div></div><div class="CompaniesGroups_categoryBox__z2NWA"><h3 class="CompaniesGroups_categoryTitle__y8Cwd">specialty groups</h3><div class="CompaniesGroups_itemsGrid__WZwNi" style="grid-template-columns:repeat(2, minmax(0, 15.6rem))"><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://bigdconstruction.com/offices/food-beverage"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="NATIONAL" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/1234af44d0f4cc.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">NATIONAL</span></a><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://bigdconstruction.com/offices/heavy-industrial"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="NATIONAL" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/1ea298c3b2fa98.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">NATIONAL</span></a><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://bigdconstruction.com/offices/mission-critical"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="NATIONAL" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/f6466f249fafa7.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">NATIONAL</span></a></div></div><div class="CompaniesGroups_categoryBox__z2NWA"><h3 class="CompaniesGroups_categoryTitle__y8Cwd">Mountain Resorts and Residences</h3><div class="CompaniesGroups_itemsGrid__WZwNi" style="grid-template-columns:minmax(0, 15.6rem)"><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://bigdsignature.com/"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="IDAHO / UTAH / WYOMING" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/6af8316d94d079.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">IDAHO / UTAH / WYOMING</span></a><a target="_blank" class="CompaniesGroups_companyItem__9N_tF" href="https://www.dovetailmontana.com/"><div class="CompaniesGroups_logoWrapper__PjtOZ"><img alt="MONTANA" loading="lazy" width="156" height="40" decoding="async" data-nimg="1" class="CompaniesGroups_logo__EHMLo" style="color:transparent" src="/assets-f/img/3b175736c6dabb.svg"></div><div class="CompaniesGroups_separator__zd3Op"></div><span class="CompaniesGroups_locationText__6ZMyf">MONTANA</span></a></div></div></div></section><section class="Offices_section__5KVwZ index_officesHome__cRxWn" id="our-companies"><div class="Offices_contentSide__zdoOm index_textContentPadding__04omA"><h2 class="Offices_title__IUA6h">18 REGIONAL offices Building projects across the united states.</h2><p class="Offices_subtitle__lD7E_">Whether our companies are navigating the complexities of an active copper mine or managing an intricate resort project at 10,000 feet elevation, we provide the nationwide reach with the personal touch of a local ally. 
